          <item>
           <property name="text">
            <string>IOS9 v1034</string>
           </property>
           <property name="toolTip">
            <string>IOS9 is used by System Menu 1.0 and early games like Zelda: Twilight Princess, Wii Sports, Wii Play, WarioWare: Smooth Moves.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS12 v526</string>
           </property>
           <property name="toolTip">
            <string>IOS12 is an IOS that was previously thought to be the oldest, used by titles such as Elebits.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS13 v1032</string>
           </property>
           <property name="toolTip">
            <string>IOS13 is used by Photo Channel 1.0.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS14 v1032</string>
           </property>
           <property name="toolTip">
            <string>IOS14 is used by Pokémon Battle Revolution (Japanese version only).</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS15 v1032</string>
           </property>
           <property name="toolTip">
            <string>IOS15 was previously used by some official channels; it has not been stubbed because the Internet Channel, which could not be updated through standard updates, previously used it.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS17 v1032</string>
           </property>
           <property name="toolTip">
            <string>IOS17 is used by early titles such as Bust-A-Move Bash and Super Paper Mario.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS21 v1039</string>
           </property>
           <property name="toolTip">
            <string>IOS21 is used by third party games (No More Heroes). many other games such as Wii Sports were also re-released under this IOS.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS22 v1294</string>
           </property>
           <property name="toolTip">
            <string>IOS22 is used by a few games like High School Musical: Sing It! and Boogie.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS28 v1807</string>
           </property>
           <property name="toolTip">
            <string>IOS28 is only used by Metroid Prime 3: Corruption. The first IOS released in modular parts.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS30 v2576</string>
           </property>
           <property name="toolTip">
            <string>IOS30 is used by System Menu 3.0-3.3. Officially this IOS is stubbed.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS31 v3608</string>
           </property>
           <property name="toolTip">
            <string>IOS31 is used by News &amp; Weather channels. RC24 (WiiLink predecessor) used to require a patched version of IOS31 so it could download custom News &amp; Weather data.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS33 v3608</string>
           </property>
           <property name="toolTip">
            <string>IOS33 is an IOS version based on IOS31 and used in games like Super Mario Galaxy.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS34 v3608</string>
           </property>
           <property name="toolTip">
            <string>IOS34 is used by Internet Channel v257.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS35 v3608</string>
           </property>
           <property name="toolTip">
            <string>IOS35 is a copy of IOS31 used by games like Call of Duty, Wii Music, etc.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS36 v3351</string>
           </property>
           <property name="toolTip">
            <string>IOS36 v3351 was the first IOS patched to restore the trucha bug, enabling custom IOS installation. Today it is recommended not to patch IOS36.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS36 v3608</string>
           </property>
           <property name="toolTip">
            <string>IOS36 v3608 is used by titles such as Super Smash Bros. Brawl and Mario Kart Wii</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS37 v5663</string>
           </property>
           <property name="toolTip">
            <string>IOS37 is used by several WiiWare games and older Guitar Hero/Rock Band games.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS38 v4124</string>
           </property>
           <property name="toolTip">
            <string>IOS38 is used by Animal Crossing: City Folk and the Nintendo Wii Speak Channel.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS41 v3607</string>
           </property>
           <property name="toolTip">
            <string>IOS41 is a Korea-specific IOS used by preinstalled channels. It is identical to IOS45.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS43 v3607</string>
           </property>
           <property name="toolTip">
            <string>IOS43 is only used by some Korean games.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS45 v3607</string>
           </property>
           <property name="toolTip">
            <string>IOS45 is only used by some Korean games. It is identical to IOS41.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS46 v3607</string>
           </property>
           <property name="toolTip">
            <string>IOS46 is an IOS used by some Korean games like Mario Kart Wii and Need for Speed Undercover.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS48 v4124</string>
           </property>
           <property name="toolTip">
            <string>IOS48 is used by Animal Crossing: City Folk (Korean version only).</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS53 v5663</string>
           </property>
           <property name="toolTip">
            <string>IOS53 is used by titles such as New Super Mario Bros. Wii and Wii Fit Plus.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS55 v5663</string>
           </property>
           <property name="toolTip">
            <string>IOS55 is used by titles such as Wii Sports Resort and The Conduit.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS56 v5662</string>
           </property>
           <property name="toolTip">
            <string>IOS56 added SDHC support and is identical to IOS61. Used by Wii Speak 2.0 and the latest Shopping Channel.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS57 v5919</string>
           </property>
           <property name="toolTip">
            <string>IOS57 is used by many of the newer games released near the end of the production of Wii discs in 2020, although it was originally released in 2009.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS58 v6176</string>
           </property>
           <property name="toolTip">
            <string>IOS58 offers improved USB2 speeds and is preferred by many apps including the Homebrew Channel.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS59 v9249</string>
           </property>
           <property name="toolTip">
            <string>IOS59 is a Japan exclusive IOS. ModMii Wizards will only direct Japanese consoles to install it.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS60 v6174</string>
           </property>
           <property name="toolTip">
            <string>IOS60 is used by System Menu 4.0 &amp; 4.1. First to support SDHC. Officially this IOS is stubbed.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS61 v5662</string>
           </property>
           <property name="toolTip">
            <string>IOS61 was used by the Wii Shop Channel from the System Menu 4.0-4.2 updates. Also used by Photo Channel 1.1b. It is identical to IOS56.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS62 v6430</string>
           </property>
           <property name="toolTip">
            <string>IOS62 is used by the Wii U Transfer Tool.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS70 v6687</string>
           </property>
           <property name="toolTip">
            <string>IOS70 is used by System Menu 4.2. Officially this IOS is stubbed.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>IOS80 v6944</string>
           </property>
           <property name="toolTip">
            <string>IOS80 is used by System Menu 4.3.</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>MIOS v10</string>
           </property>
           <property name="toolTip">
            <string>MIOS is a special version of IOS that runs when the Wii enters GameCube mode</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>vWii IOSs [x29]</string>
           </property>
           <property name="toolTip">
            <string>Download 29 IOSs for vWii:
                                                                              vIOS9, 12, 13, 14, 15, 17, 21, 22, 28, 31, 33, 34, 35, 36, 37, 38, 41, 43, 45, 46, 48, 53, 55, 56, 57, 58, 59, 62 &amp; 80.

                                                                              While effectively these IOSs are not patched, technically they are fakesigned and re-encrypted to use the Wii retail common key so that they can be installed using WAD Managers available today.

                                                                              ...I know what you're thinking and the answer is yes, shortcuts were taken.</string>
           </property>
          </item>
         </widget>
        </widget>
